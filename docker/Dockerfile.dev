#
# Development / CI base image: SBCL + Go + build tools.
# Used by the GitLab pipeline and by `make` on developer workstations
# that prefer not to install SBCL+Go locally.

FROM debian:12-slim

ARG SBCL_VERSION=2.4.0
ARG GO_VERSION=1.22.5
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        make \
        build-essential \
        pkg-config \
        libev-dev \
        libssl-dev \
        libbz2-dev \
        sbcl \
        sqlite3 \
        libsqlite3-dev \
        libpq-dev \
        coreutils \
        findutils \
    && rm -rf /var/lib/apt/lists/*

# Go: use the official tarball, not the distro package, to pin the version.
RUN set -eux; \
    case "${TARGETARCH:-amd64}" in \
        amd64) GOARCH=amd64 ;; \
        arm64) GOARCH=arm64 ;; \
        *) echo "unsupported arch: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GOARCH}.tar.gz" \
        | tar -C /usr/local -xz; \
    ln -s /usr/local/go/bin/go /usr/local/bin/go; \
    ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt

# Quicklisp + the server's Common Lisp dependencies, baked into the image
# so CI builds don't pay the download cost on every run. Versions float
# (Quicklisp dist of the day at image build time); the image tag is
# rebuilt on master pushes so the cache stays reasonably fresh.
RUN curl -fsSL https://beta.quicklisp.org/quicklisp.lisp -o /tmp/quicklisp.lisp \
    && sbcl --non-interactive --no-userinit --no-sysinit \
        --load /tmp/quicklisp.lisp \
        --eval '(quicklisp-quickstart:install :path "/opt/quicklisp")' \
        --eval '(quit)' \
    && sbcl --non-interactive --no-userinit --no-sysinit \
        --load /opt/quicklisp/setup.lisp \
        --eval '(ql:quickload (list "alexandria" "ironclad" "com.inuoe.jzon" "cl-dbi" "cl-sqlite" "cl-postgres" "clack" "woo" "cl+ssl" "dexador" "fiveam"))' \
        --eval '(quit)' \
    && rm /tmp/quicklisp.lisp

ENV GOPATH=/go
ENV PATH=/go/bin:/usr/local/go/bin:${PATH}
ENV CGO_ENABLED=0
# Quicklisp is installed at /opt/quicklisp; build.lisp finds setup.lisp
# at $(QUICKLISP_HOME)/quicklisp/setup.lisp -> /opt/quicklisp/setup.lisp.
ENV QUICKLISP_HOME=/opt

WORKDIR /workspace
