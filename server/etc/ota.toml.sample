#
# Sample configuration for a single-host install of ota-server
# unpacked from delta-ota-server-X.Y.Z.tar.gz.
#
# This layout assumes the standard install paths used by
# etc/ota-server.service:
#   /opt/ota/        — application bits (core image + helpers)
#   /var/lib/ota/    — data directory (blobs, patches, db, keys)
#   /etc/ota/        — configuration + TLS material
#
# This file is intended for evaluation / debugging hosts. Production
# deployments should use the published container image — see
# docs/operations.org.

[server]
# The recommended deployment terminates TLS at a reverse proxy
# (nginx, HAProxy, …) and binds the server to localhost. To expose
# the server directly on the public interface, configure [tls] below
# and switch to "0.0.0.0:8443".
listen     = "127.0.0.1:8443"
hostname   = "ota.example.com"
data_dir   = "/var/lib/ota"
log_level  = "info"
# Number of Woo worker threads.  Each runs its own libev loop and
# shares the listening socket; one slow handler does not wedge the
# others.  Set to roughly your CPU count for read-heavy traffic
# (10k clients fetching manifests + sendfile blobs on first-Monday
# upgrades).  Defaults to 4 when omitted.
worker_num = 4

# Admin bearer token. Required for every endpoint under /v1/admin/.
# Either set OTA_ADMIN_TOKEN in the environment (recommended -- avoids
# storing the secret in a config file under git or backup) OR set the
# value here.  Env-var wins when both are set.  See operations.org
# section "Authentication" for rotation procedure.
# admin_token = "REPLACE-ME-WITH-A-RANDOM-32-BYTE-HEX-STRING"

[tls]
# Uncomment when terminating TLS in the server itself (no proxy).
# cert         = "/etc/ota/server.crt"
# key          = "/etc/ota/server.key"
# client_ca    = "/etc/ota/clients-ca.crt"
require_mtls = false

# --- v1.4: admin cert-subject identity (ADR-0009) ----------------------
# The standard deployment terminates TLS + mTLS at a reverse proxy
# (nginx, HAProxy, …) and forwards the verified client certificate's
# Subject DN as an HTTP header.  Turn this knob on so the server
# trusts that header; leave it off in deployments where the upstream
# is untrusted (any direct-public ota-server, any proxy not under
# your control).
# trust_proxy_subject_header = false
# proxy_subject_header_name  = "x-ota-client-cert-subject"  # nginx-emitted alternatives: "x-client-dn", "ssl-client-s-dn"

# Strict allowlist of Subject DN strings allowed to use admin
# endpoints.  When non-empty, a bearer token alone is no longer
# sufficient -- the request must also carry one of these subjects
# in the proxy header.  Defense in depth: a leaked admin token by
# itself cannot publish or rotate keys.
# admin_subjects = [
#   "CN=alice@example.com,O=Example",
#   "CN=bob@example.com,O=Example",
# ]

# When require_mtls = true, admin endpoints reject every request
# that does NOT carry a recognised cert subject -- even with a
# valid bearer token.  Combine with admin_subjects for the
# strictest deployment.

[storage]
backend = "fs"

[catalogue]
db = "sqlite:/var/lib/ota/db/ota.db"

[patcher]
default      = "bsdiff"
worker_count = 2
bsdiff_path  = "/opt/ota/bin/bsdiff"
bspatch_path = "/opt/ota/bin/bspatch"
# xdelta3 is intentionally not configured: see docs/adr/0004-bsdiff-only-no-xdelta3.org

[gc]
default_threshold = 0
schedule          = "0 3 * * *"

[install_token]
ttl_seconds = 900

# --- v1.4: per-endpoint rate limits (ADR-0009 §4) -----------------------
# Each row caps one route's token bucket -- format "CAPACITY/REFILL"
# where REFILL is tokens/sec (fractional OK; "1/60" = one per minute).
# Routes not listed inherit the built-in admin defaults or, for
# non-admin routes, the v1.3 generic budget (600 tokens, 10/sec).
# These caps stack on top of the per-identity rule: each (identity,
# route) pair gets its own bucket, so one operator's burst does not
# starve another.
# [rate_limits]
# admin-publish-release            = "10/0.166"   # 10 publishes/min
# admin-mint-install-token         = "60/1"       # 1/sec
# admin-mint-install-tokens-batch  = "5/0.0166"   # 5 batches/hr
# admin-build-reverse-patch        = "10/0.166"
# admin-mark-uncollectable         = "30/0.5"
# admin-gc                         = "6/0.0166"
# admin-verify                     = "6/0.0166"
